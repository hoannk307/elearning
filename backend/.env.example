# Backend env — copy sang .env rồi điền giá trị thật
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/kids_lms?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379

# Anthropic Claude — lấy key tại https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — lấy key tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model AI mặc định khi chưa chọn trong giao diện
# id hợp lệ: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5 | gemini-2.5-pro | gemini-2.5-flash
AI_DEFAULT_MODEL=claude-sonnet-4-6

PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads
APP_PIN=1234

# Cloudflare R2 (lưu trữ ảnh bài làm) — tạo token tại Cloudflare Dashboard > R2 > Manage API Tokens
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Tùy chọn: custom domain hoặc r2.dev đã bật Public access cho bucket.
# Bỏ trống sẽ dùng endpoint R2 trực tiếp (cần bật Public access cho bucket).
R2_PUBLIC_BASE_URL=
