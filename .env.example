# ─── Database (khớp với docker-compose.yml) ───────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/kids_lms?schema=public"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Anthropic Claude API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Backend ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads

# ─── Auth (PIN đơn giản) ──────────────────────────────────────────────────
APP_PIN=1234
