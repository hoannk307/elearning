# Caddy chỉ làm reverse proxy nội bộ qua HTTP (cổng 80 trong container,
# map ra 127.0.0.1:8080 trên host). HTTPS do nginx/apache phía trước lo.
# KHÔNG dùng tên domain ở đây để Caddy không cố xin chứng chỉ Let's Encrypt.

:80 {
	# API → backend NestJS
	handle /api/* {
		reverse_proxy backend:3004
	}

	# Ảnh/file cũ còn phục vụ tĩnh bởi backend (ảnh mới dùng URL R2)
	handle /uploads/* {
		reverse_proxy backend:3004
	}

	# Còn lại → frontend Next.js
	handle {
		reverse_proxy frontend:3005
	}
}
