# ===== Production stack (.env ở ROOT, dùng cho docker-compose.prod.yml) =====
# Copy thành .env trên VPS rồi điền giá trị thật. KHÔNG commit file .env.

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=thay-bang-mat-khau-manh
POSTGRES_DB=kids_lms

# --- Domain (cho CORS backend) ---
FRONTEND_URL=https://your-domain.com

# --- AI keys ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6

# --- App ---
APP_PIN=1234

# --- Cloudflare R2 ---
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=elearning
R2_PUBLIC_BASE_URL=https://cdn.your-domain.com

# Ghi chú: DATABASE_URL và REDIS_HOST đã được set sẵn trong docker-compose.prod.yml,
# không cần khai báo ở đây.
